  "transaction_map": {
    "name": "트랜잭션 맵",
    "description": "분산 트랜잭션의 호출 관계를 시각화. 응답시간, SQL 시간, fetch 수 등 트랜잭션 상세 데이터.",
    "mxqlPaths": [],
    "tagCountCategories": [],
    "yardApis": [
      {
        "type": "txmap",
        "path": "/realtime",
        "description": "실시간 트랜잭션 데이터",
        "fields": [
          "txid",
          "elapsed",
          "sqlTime",
          "sqlCount",
          "fetchTime",
          "fetchCount",
          "cpu",
          "mem",
          "service",
          "ip",
          "domain"
        ]
      },
      {
        "type": "txmap/v2",
        "path": "/read",
        "description": "디스크 트랜잭션 조회 (시간범위)",
        "fields": [
          "txid",
          "elapsed",
          "sqlTime",
          "sqlCount",
          "cpu",
          "mem"
        ]
      }
    ],
    "domainKnowledge": [
      "Yard API(txmap) 사용 — whatap_yard_query(type='txmap', path='/realtime')로 조회",
      "elapsed: 트랜잭션 응답시간(ms), sqlTime: SQL 수행시간(ms), sqlCount: SQL 호출 수",
      "fetchTime: fetch 시간(ms), fetchCount: fetch 수, cpu: CPU 사용(ms), mem: 메모리(bytes)"
    ]
  },
